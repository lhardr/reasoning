# Direct provider keys — used when present, preferred over OpenRouter.
DEEPSEEK_API_KEY=
ZAI_API_KEY=
MOONSHOT_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# OpenRouter gateway (https://openrouter.ai) — used as fallback when a direct
# provider key is absent. Covers most scored models via a single key.
# Note: OpenRouter may drop or transform reasoning fields; the smoke test verifies.
OPENROUTER_API_KEY=

# Gemma 4 runs locally via Ollama — no key needed.
# Judges — Phase 2 (not called in Phase 0)
# MINIMAX_API_KEY=
# GOOGLE_API_KEY=

# --tools phase: web_search backend (brave | tavily). If SEARCH_API_KEY is
# missing, web_search is omitted from the tool list (logged as pending) and
# python_exec still runs — the repl measurement is never blocked by this.
SEARCH_PROVIDER=brave
SEARCH_API_KEY=
